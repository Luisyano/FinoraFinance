@model List<FinoraFinance.Models.Transaccion>

@{
    ViewData["Title"] = "Mis Registros";
    int pagina = ViewBag.Page ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 0;
    string busqueda = ViewBag.Search ?? "";
    string ordenActual = ViewBag.Orden ?? "fecha_desc";
    int pageSize = ViewBag.PageSize ?? 10;
}

<style>
    .search-container {
        display: flex;
        gap: 0.75rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        align-items: center;
    }

    .search-input {
        flex: 1;
        min-width: 200px;
    }

    #ordenSelect {
        background: #2A2A2A;
        border: 1px solid #333;
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        cursor: pointer;
        min-width: 200px;
    }

    #btnBuscar {
        background: #F4C542;
        color: #121212;
        border: none;
        padding: 0.5rem 1.2rem;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }

        #btnBuscar:hover {
            background: #FFE08A;
            transform: translateY(-2px);
        }

    #btnLimpiar {
        background: transparent;
        border: 2px solid #F4C542;
        color: #F4C542;
        padding: 0.5rem 1.2rem;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }

        #btnLimpiar:hover {
            background: #F4C542;
            color: #121212;
            transform: translateY(-2px);
        }

    nav.mt-3 {
        margin-top: 2rem;
    }

    .pagination {
        display: flex;
        gap: 0.5rem;
        list-style: none;
        justify-content: center;
        padding: 0;
    }

    .page-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.9rem;
        background: #2A2A2A;
        border: 1px solid #333;
        color: #B3B3B3;
        border-radius: 8px;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s;
        font-size: 0.9rem;
    }

        .page-link:hover {
            background: #F4C542;
            color: #121212;
            transform: translateY(-2px);
        }

    .page-item.disabled .page-link {
        opacity: 0.5;
        cursor: not-allowed;
    }


</style>

<div class="card">
    <div class="card-header">
        <h2>Mis Registros</h2>
        <h3>Historial de ingresos y gastos</h3>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="mb-5" style="margin-bottom: 2rem;">
        <a asp-action="Create" class="btn btn-primary">
            <i class='bx bx-plus'></i> Nuevo Registro
        </a>
    </div>

    <div class="search-container">
        <input type="text" id="searchInput" class="form-control search-input" placeholder="Buscar por nota o etiqueta..." value="@busqueda" />
        <select id="ordenSelect">
            <option value="fecha_desc" selected="@(ordenActual == "fecha_desc")">Fecha (más reciente)</option>
            <option value="fecha_asc" selected="@(ordenActual == "fecha_asc")">Fecha (más antiguo)</option>
            <option value="monto_desc" selected="@(ordenActual == "monto_desc")">Monto (mayor a menor)</option>
            <option value="monto_asc" selected="@(ordenActual == "monto_asc")">Monto (menor a mayor)</option>
        </select>
        <button type="button" id="btnBuscar">
            <i class='bx bx-search-alt-2'></i> Buscar
        </button>
        <button type="button" id="btnLimpiar">
            <i class='bx bx-reset'></i> Limpiar
        </button>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class='bx bx-info-circle'></i> No tienes registros. Haz clic en "Nuevo Registro" para comenzar.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr>
                        <th style="padding: 12px; text-align: left; border-bottom: 1px solid #333; color: #F4C542; background-color: #2A2A2A;">Fecha</th>
                        <th style="padding: 12px; text-align: left; border-bottom: 1px solid #333; color: #F4C542; background-color: #2A2A2A;">Tipo</th>
                        <th style="padding: 12px; text-align: left; border-bottom: 1px solid #333; color: #F4C542; background-color: #2A2A2A;">Cuenta</th>
                        <th style="padding: 12px; text-align: left; border-bottom: 1px solid #333; color: #F4C542; background-color: #2A2A2A;">Etiqueta</th>
                        <th style="padding: 12px; text-align: left; border-bottom: 1px solid #333; color: #F4C542; background-color: #2A2A2A;">Monto</th>
                        <th style="padding: 12px; text-align: left; border-bottom: 1px solid #333; color: #F4C542; background-color: #2A2A2A;">Nota</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom: 1px solid #333;">
                            <td style="padding: 12px;">@item.Fecha.ToShortDateString()</td>
                            <td style="padding: 12px;">
                                @if (item.Tipo == "Ingreso")
                                {
                                    <span style="color: #4CAF50;"><i class='bx bx-dollar-circle'></i> @item.Tipo</span>
                                }
                                else if (item.Tipo == "Gasto")
                                {
                                    <span style="color: #F44336;"><i class='bx bx-shopping-bag'></i> @item.Tipo</span>
                                }
                                else
                                {
                                    <span style="color: #F4C542;"><i class='bx bx-pizza'></i> @item.Tipo</span>
                                }
                            </td>
                            <td style="padding: 12px;">@item.Cuenta?.Nombre</td>
                            <td style="padding: 12px;">@item.Etiqueta?.Nombre</td>
                            <td style="padding: 12px;">
                                <span style="@(item.Tipo == "Ingreso" ? "color: #4CAF50;" : "color: #F44336;") font-weight: bold;">
                                    @(item.Tipo == "Ingreso" ? "+" : "-") @item.Monto.ToString("C")
                                </span>
                            </td>
                            <td style="padding: 12px;">@item.Nota</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPaginas > 1)
        {
            <nav class="mt-3">
                <ul class="pagination">
                    @if (pagina > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="javascript:void(0);" onclick="irPagina(@(pagina - 1))">
                                <i class='bx bx-chevron-left'></i> Anterior
                            </a>
                        </li>
                    }
                    <li class="page-item disabled">
                        <span class="page-link">Página @pagina de @totalPaginas</span>
                    </li>
                    @if (pagina < totalPaginas)
                    {
                        <li class="page-item">
                            <a class="page-link" href="javascript:void(0);" onclick="irPagina(@(pagina + 1))">
                                Siguiente <i class='bx bx-chevron-right'></i>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>

@section Scripts {
    <script>
        function irPagina(pagina) {
            var busqueda = document.getElementById('searchInput').value;
            var orden = document.getElementById('ordenSelect').value;
            window.location.href = '@Url.Action("Lista", "Transacciones")?page=' + pagina + '&search=' + encodeURIComponent(busqueda) + '&orden=' + orden + '&pageSize=@pageSize';
        }

        document.getElementById('btnBuscar').addEventListener('click', function() {
            var busqueda = document.getElementById('searchInput').value;
            var orden = document.getElementById('ordenSelect').value;
            window.location.href = '@Url.Action("Lista", "Transacciones")?search=' + encodeURIComponent(busqueda) + '&orden=' + orden + '&pageSize=@pageSize';
        });

        document.getElementById('btnLimpiar').addEventListener('click', function() {
            window.location.href = '@Url.Action("Lista", "Transacciones")?pageSize=@pageSize';
        });
    </script>
}