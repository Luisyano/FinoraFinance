@model FinoraFinance.Models.Vista.Registrarse

@{
    ViewData["Title"] = "Registrarse";
}

<div class="card">
    <div class="card-header">
        <h2>Crear una cuenta</h2>
        <h3>Comienza a controlar tus finanzas</h3>
    </div>

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-success">@ViewBag.Mensaje</div>
    }

    <form asp-action="Registrarse" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="form-group">
            <label asp-for="Email">Correo Electrónico</label>
            <input asp-for="Email" class="form-control" placeholder="ejemplo@correo.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Telefono">Teléfono</label>
            <input asp-for="Telefono" class="form-control" placeholder="987654321" />
            <span asp-validation-for="Telefono" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password">Contraseña</label>
            <input asp-for="Password" class="form-control" type="password" placeholder="********" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="ConfirmPassword">Confirmar Contraseña</label>
            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="********" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="FullName">Nombre Completo</label>
            <input asp-for="FullName" class="form-control" placeholder="Juan Pérez" />
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary btn-block">Registrarse</button>
    </form>

    <div class="text-center mt-3">
        <p>¿Ya tienes cuenta? <a asp-action="IniciarSesion">Inicia sesión aquí</a></p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}