<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Finora Finance</title>
    <link rel="stylesheet" href="~/css/style.css" />
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <a href="/" class="logo">Finora<span>Finance</span></a>
            <ul class="nav-links">
                <li><a href="/">Inicio</a></li>
                <li><a href="/Home/Privacy">Privacidad</a></li>
                @if (User.Identity.IsAuthenticated)
                {
                    <li>
                        <form asp-controller="Account" asp-action="CerrarSesion" method="post" style="display:inline;">
                            <button type="submit" style="background:none; border:none; color:#B3B3B3; cursor:pointer; font-size:1rem;">Cerrar Sesión</button>
                        </form>
                    </li>
                }
                else
                {
                    <li><a asp-controller="Account" asp-action="Registrarse">Registrarse</a></li>
                    <li><a asp-controller="Account" asp-action="IniciarSesion">Iniciar Sesión</a></li>
                }
            </ul>
        </div>
    </nav>

    <main class="container">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; @DateTime.Now.Year - Finora Finance - Controla tus finanzas</p>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>